<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle configuration for Bookstore OOP Assignment.
  Rules are intentionally student-friendly ‚Äî catches real issues
  without being overly pedantic.
-->
<module name="Checker">
  <property name="severity" value="error"/>

  <module name="TreeWalker">

    <!-- ‚îÄ‚îÄ Naming conventions ‚îÄ‚îÄ -->
    <module name="TypeName">
      <message key="name.invalidPattern"
        value="Class name ''{0}'' must start with an uppercase letter."/>
    </module>
    <module name="MethodName">
      <message key="name.invalidPattern"
        value="Method name ''{0}'' must start with a lowercase letter."/>
    </module>
    <module name="LocalVariableName"/>
    <module name="MemberName"/>
    <module name="ParameterName"/>
    <module name="ConstantName"/>

    <!-- ‚îÄ‚îÄ Encapsulation checks ‚îÄ‚îÄ -->
    <module name="VisibilityModifier">
      <!-- Allow protected fields in abstract classes (Service) -->
      <property name="protectedAllowed" value="true"/>
      <property name="packageAllowed"   value="false"/>
    </module>

    <!-- ‚îÄ‚îÄ Code structure ‚îÄ‚îÄ -->
    <module name="EmptyBlock">
      <property name="option" value="text"/>
    </module>
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>

    <!-- ‚îÄ‚îÄ OOP best practices ‚îÄ‚îÄ -->
    <module name="SuperClone"/>
    <module name="SuperFinalize"/>
    <module name="AbstractClassName">
      <!-- Ensures abstract classes are named clearly -->
      <property name="format" value="^Abstract.*$|^.*Service$|^.*Base$"/>
      <property name="ignoreModifier" value="true"/>
    </module>

    <!-- ‚îÄ‚îÄ Avoid common mistakes ‚îÄ‚îÄ -->
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="ignored|expected"/>
    </module>
    <module name="StringLiteralEquality"/>
    <module name="EqualsHashCode"/>
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>
    <module name="DefaultComesLast"/>

    <!-- ‚îÄ‚îÄ Whitespace / formatting ‚îÄ‚îÄ -->
    <module name="WhitespaceAround">
        <property name="allowEmptyConstructors" value="true"/>
        <property name="allowEmptyMethods"      value="true"/>
    </module>
    <module name="NoWhitespaceAtEndOfLine"/>

    <!-- ‚îÄ‚îÄ Import hygiene ‚îÄ‚îÄ -->
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>

  </module>

  <!-- File-level: no trailing whitespace, UTF-8 -->
  <module name="NewlineAtEndOfFile">
    <property name="lineSeparator" value="lf"/>
  </module>
  <module name="FileTabCharacter">
    <property name="eachLine" value="false"/>
  </module>

</module>
